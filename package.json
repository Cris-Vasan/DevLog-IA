{
  "name": "devlog-ai",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "npm --prefix server run dev",
    "dev:client": "npm --prefix client run dev",
    "test": "npm run test:server",
    "test:server": "npm --prefix server test"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
